{
  "name": "localeja",
  "version": "0.1.0",
  "main": "index.js",
  "repository": "https://github.com/mkusaka/localeja.git",
  "author": "mkusaka <hinoshita1992@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@crxjs/vite-plugin": "2.4.0",
    "@types/chrome": "0.1.39",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "typescript": "5.9.3",
    "vite": "8.0.3"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --import-plugin --tsconfig ./tsconfig.json",
    "lint:fix": "oxlint . --import-plugin --tsconfig ./tsconfig.json --fix",
    "lint:ci": "oxlint . --import-plugin --tsconfig ./tsconfig.json --deny-warnings",
    "package": "rm -f package.zip && pnpm build && cd dist && zip -r ../package.zip ."
  }
}
