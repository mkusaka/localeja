{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 100,
  "arrowParens": "always",
  "endOfLine": "lf",
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules/",
    "pnpm-lock.yaml",
    "dist/",
    ".idea/",
    ".vscode/",
    "package.zip",
    "*.log"
  ]
}
